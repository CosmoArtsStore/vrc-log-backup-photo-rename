{
    "name": "stella-record",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "stella_record_ui"
    ],
    "scripts": {
        "build:Polaris-pkg": "npm run build:Polaris-bin && cd Polaris && npx tauri build --bundles nsis",
