{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Polaris",
    "version": "1.0.0",
    "identifier": "com.cosmoartsstore.stellarecord",
    "build": {
        "beforeBuildCommand": "",
        "frontendDist": null
    },
    "app": {
        "windows": [],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "template": "windows/installer.nsi",
                "installerHooks": "windows/hooks.nsi",
                "installerIcon": "icons/icon.bmp",
                "headerImage": "icons/icon.bmp",
                "sidebarImage": "icons/icon.bmp",
                "languages": [
                    "Japanese"
                ]
            }
        }
    }
}