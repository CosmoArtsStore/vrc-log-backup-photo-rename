## 3. usePhashWorker.ts（新規作成）

```typescript
export function usePhashWorker() {
    const [progress, setProgress] = useState({ done: 0, total: 0 });
    const [isRunning, setIsRunning] = useState(false);

    useEffect(() => {
        // 進捗イベント受信
        const unlisten1 = listen("phash_progress", () => {
            setIsRunning(true);
            setProgress(prev => ({ ...prev, done: prev.done + 1 }));
        });

        // 完了イベント受信
        const unlisten2 = listen("phash_complete", () => {
            setIsRunning(false);
        });

        return () => {
            unlisten1.then(f => f());
            unlisten2.then(f => f());
        };
    }, []);

    return { progress, isRunning };
}
```

